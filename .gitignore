# R
.Rhistory
.RData
.RDataTmp*
.Rproj.user/
*.Rproj

# Environment / secrets
.env
.Renviron

# OS
.DS_Store

# Claude Code (local only)
CLAUDE.md
.claude/

# Data files — not tracked (too large / binary / not source code)
# versions/*.json are source code and ARE tracked
# data/ subdirectory contents (gis, remote_sensing, socio-economic) ARE tracked
data/*.csv
data/*.json
**/*.rds
**/*.html
**/*.pdf

# Output and doc directories — track folder structure only via .gitkeep
docs/*
outputs/*
data_dictionnaries/*

# Always allow .gitkeep to preserve empty dirs
!**/.gitkeep
