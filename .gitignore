# R
.Rhistory
.RData
.RDataTmp*
.Rproj.user/
*.Rproj

# Environment / secrets
.env
.Renviron

# OS
.DS_Store

# Claude Code (local only)
CLAUDE.md
.claude/

# Data files — not tracked (too large / binary / not source code)
# versions/*.json are source code and ARE tracked
**/*.csv
**/*.xlsx
**/*.xls
**/*.zip
**/*.rds
**/*.html
**/*.pdf
**/*.shp
**/*.dbf
**/*.shx
**/*.prj
**/*.cpg
**/*.sbn
**/*.sbx

# Data, output, and doc directories — track folder structure only via .gitkeep
data/*
docs/*
outputs/*
data_dictionnaries/*

# Always allow .gitkeep to preserve empty dirs
!**/.gitkeep
